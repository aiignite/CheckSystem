<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <ShowTitle>EP33-ISC-后灯B</ShowTitle>
  <Init>
    <EnterFunction>
      Ep33IscRearLamp.Field.CanFd=ZlgUsbCanFd200U.Field.ZlgCanChannel0;
      Ep33IscRearLamp.Method.ChangeToRclb();
    </EnterFunction>
  </Init>
  <ControllerConfig>
    <Controller>
      <ControllerType>Ep33IscRearLamp</ControllerType>
      <ControllerName>Ep33IscRearLamp</ControllerName>
    </Controller>
    <Controller>
      <ControllerType>ZlgUsbCanFd200U</ControllerType>
      <ControllerName>ZlgUsbCanFd200U</ControllerName>
    </Controller>
  </ControllerConfig>
  <Buttons>
    <Button>
      <Method>
        Ep33IscRearLamp.Method.RedLedOn(63);
      </Method>
      <Text>按25%亮度点亮红光</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Ep33IscRearLamp.Method.RedLedOn(127);
      </Method>
      <Text>按50%亮度点亮红光</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Ep33IscRearLamp.Method.RedLedOn(191);
      </Method>
      <Text>按75%亮度点亮红光</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Ep33IscRearLamp.Method.RedLedOn(255);
      </Method>
      <Text>按100%亮度点亮红光</Text>
      <Para></Para>
    </Button>

    <Button>
      <Method>
        Ep33IscRearLamp.Method.YelowLedOn(63);
      </Method>
      <Text>按25%亮度点亮黄光</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Ep33IscRearLamp.Method.YelowLedOn(127);
      </Method>
      <Text>按50%亮度点亮黄光</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Ep33IscRearLamp.Method.YelowLedOn(191);
      </Method>
      <Text>按75%亮度点亮黄光</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Ep33IscRearLamp.Method.YelowLedOn(255);
      </Method>
      <Text>按100%亮度点亮黄光</Text>
      <Para></Para>
    </Button>

    <Button>
      <Method>
        Ep33IscRearLamp.Method.AllLedOff();
      </Method>
      <Text>关灯</Text>
      <Para></Para>
    </Button>
  </Buttons>
</EmulatorConfig>