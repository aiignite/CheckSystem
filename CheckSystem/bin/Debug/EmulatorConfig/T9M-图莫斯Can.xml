<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <ShowTitle>T9M-图莫斯Can</ShowTitle>
    <Init>
        <EnterFunction>
            T9M.Field.CanFd=ToomossUsb2XxxCanLin.Field.Can1;
            T9M.Method.StartCanMsg();
        </EnterFunction>
    </Init>
    <ControllerConfig>
        <Controller>
            <ControllerType>ToomossUsb2XxxCanLin</ControllerType>
            <ControllerName>ToomossUsb2XxxCanLin</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>T9M</ControllerType>
            <ControllerName>T9M</ControllerName>
        </Controller>
    </ControllerConfig>
    <Buttons>
        <Button>
            <Method>
                T9M.Method.StartCan();
            </Method>
            <Text>打开CAN</Text>
            <Para></Para>
        </Button>

        <Button>
            <Method>
                T9M.Method.StopCan();
            </Method>
            <Text>关闭CAN</Text>
            <Para></Para>
        </Button>

        <Button>
            <Method>
                T9M.Method.ClearReadResult();
                T9M.Method.ReadBootVer();
                T9M.Method.ReadAppVer();
                T9M.Method.ReadHwVer();
                T9M.Method.ReadSwVer();
                T9M.Method.ReadPartNo();
                T9M.Method.ReadMaterialVersionNumber();
                T9M.Method.ReadFactoryMode();
                T9M.Method.ReadSwChildVer();
            </Method>
            <Text>读版本信息</Text>
            <Para></Para>
        </Button>    
    </Buttons>
    <GridDatas>
        <GridData>
            <Name>读取Boot版本号</Name>
            <Type>T9M.Field.BootVer</Type>
        </GridData>
        
        <GridData>
            <Name>读取零件号</Name>
            <Type>T9M.Field.PartNo</Type>
        </GridData>
        <GridData>
            <Name>读取硬件版本号</Name>
            <Type>T9M.Field.HwVer</Type>
        </GridData>
        <GridData>
            <Name>读取软件版本号</Name>
            <Type>T9M.Field.SwVer</Type>
        </GridData>
        <GridData>
            <Name>读取App版本号</Name>
            <Type>T9M.Field.AppVer</Type>
        </GridData>
        <GridData>
            <Name>读取素材版本号</Name>
            <Type>T9M.Field.MaterialVersionNumber</Type>
        </GridData>
        <GridData>
            <Name>读取工厂模式</Name>
            <Type>T9M.Field.FactoryMode</Type>
        </GridData>
        <GridData>
            <Name>读取软件子版本号</Name>
            <Type>T9M.Field.SwChildVer</Type>
        </GridData>
    </GridDatas>
</EmulatorConfig>