<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <ShowTitle>E001前灯-用瑞萨板</ShowTitle>
    <Init>
        <EnterFunction>
            SyRenesasMcuControllerMaster.Method.InitRemoteIpAddress(192.168.1.28:8088);
            E001HeadLamp.Field.Can=SyRenesasMcuControllerMaster.Field.GatewayCan1;
            E001HeadLamp.Method.ModuleAwake();
        </EnterFunction>
    </Init>
    <ControllerConfig>
        <Controller>
            <ControllerType>SyRenesasMcuControllerMaster</ControllerType>
            <ControllerName>SyRenesasMcuControllerMaster</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>E001HeadLamp</ControllerType>
            <ControllerName>E001HeadLamp</ControllerName>
        </Controller>
    </ControllerConfig>
    <Buttons>
        <Button>
            <Method>
                E001HeadLamp.Method.LeftLowBeamOn();
            </Method>
            <Text>左近光打开</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                E001HeadLamp.Method.LeftLowBeamOff();
            </Method>
            <Text>左近光关闭</Text>
            <Para></Para>
        </Button>

        <Button>
            <Method>
                E001HeadLamp.Method.RightLowBeamOn();
            </Method>
            <Text>右近光打开</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                E001HeadLamp.Method.RightLowBeamOff();
            </Method>
            <Text>右近光关闭</Text>
            <Para></Para>
        </Button>

        <Button>
