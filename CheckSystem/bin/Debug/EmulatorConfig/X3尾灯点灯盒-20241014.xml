<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <ShowTitle>小鹏X3后灯-点灯盒</ShowTitle>
    <Init>
        <EnterFunction>
            SyRenesasMcuControllerMaster.Method.InitRemoteIpAddress(192.168.1.28:8088);
            XiaoPengX3RearLamp.Field.Can=SyRenesasMcuControllerMaster.Field.GatewayCan1;
            XiaoPengX3RearLamp.Field.IsLConnect=1;
            XiaoPengX3RearLamp.Field.IsRConnect=1;
            XiaoPengX3RearLamp.Method.StartCanMsg();
        </EnterFunction>
    </Init>
    <ControllerConfig>
        <Controller>
            <ControllerType>XiaoPengX3RearLamp</ControllerType>
            <ControllerName>XiaoPengX3RearLamp</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>ToomossUsb2XxxCanLin</ControllerType>
            <ControllerName>ToomossUsb2XxxCanLin</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>SyRenesasMcuControllerMaster</ControllerType>
            <ControllerName>SyRenesasMcuControllerMaster</ControllerName>
        </Controller>
    </ControllerConfig>
    <Buttons>

        <Button>
            <Method>
                XiaoPengX3RearLamp.Method.PosOn();
            </Method>
            <Text>位置灯亮</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                XiaoPengX3RearLamp.Method.PosOff();
            </Method>
            <Text>位置灯灭</Text>
            <Para></Para>
        </Button>

        <Button>
            <Method>
                XiaoPengX3RearLamp.Method.StopCdcuControl();
                XiaoPengX3RearLamp.Method.TurnLOn(1);
                XiaoPengX3RearLamp.Method.TurnROn(1);
            </Method>
            <Text>转向灯流水点亮</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                XiaoPengX3RearLamp.Method.StopCdcuControl();
                XiaoPengX3RearLamp.Method.YellowAllOff();
