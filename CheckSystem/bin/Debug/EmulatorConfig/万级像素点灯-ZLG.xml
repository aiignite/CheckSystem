<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <ShowTitle>万级像素点灯-ZLG</ShowTitle>
    <Init>
        <EnterFunction>
            KebodaLdmSeries.Field.Can=ZlgUsbCanFd200U.Field.ZlgCanChannel0;
            KebodaLdmSeries.Method.ModuleAwake();
            KebodaLdmSeries.Method.LeavingHomeActive();
        </EnterFunction>
    </Init>
    <ControllerConfig>
        <Controller>
            <ControllerType>KebodaLdmSeries</ControllerType>
            <ControllerName>KebodaLdmSeries</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>ZlgUsbCanFd200U</ControllerType>
            <ControllerName>ZlgUsbCanFd200U</ControllerName>
        </Controller>
    </ControllerConfig>
    <Buttons>

        <Button>
            <Method>
                KebodaLdmSeries.Method.LeavingHomeActive();
            </Method>
            <Text>ON</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                KebodaLdmSeries.Method.LeavingHomeNotActive();
            </Method>
            <Text>OFF</Text>
            <Para></Para>
        </Button>

    </Buttons>
    <GridDatas>
    </GridDatas>
</EmulatorConfig>