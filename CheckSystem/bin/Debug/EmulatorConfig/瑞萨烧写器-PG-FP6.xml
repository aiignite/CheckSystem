<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <ShowTitle>瑞萨烧写器-PG-FP6</ShowTitle>
  <Init>
    <EnterFunction>
      RenesasFgFp6.Method.ConnectFp6(COM2:9600);
      RenesasFgFp6.Field.IdCodeToSet=FF8CC547113BFEFA98897DDFF3548FCA;
      RenesasFgFp6.Field.AuthId=FF8CC547113BFEFA98897DDFF3548FCA;
    </EnterFunction>
  </Init>
  <ControllerConfig>
    <Controller>
      <ControllerType>RenesasFgFp6</ControllerType>
      <ControllerName>RenesasFgFp6</ControllerName>
    </Controller>
    <Controller>
      <ControllerType>CheckApp</ControllerType>
      <ControllerName>CheckApp</ControllerName>
    </Controller>
  </ControllerConfig>
  <Buttons>
    <Button>
      <Method>
        RenesasFgFp6.Method.ConnectDevice();
        CheckApp.Method.Sleep(50);
        RenesasFgFp6.Method.ReadIcuS();
      </Method>
      <Text>读ICUS</Text>
      <Para></Para>
    </Button>

    <Button>
      <Method>
        RenesasFgFp6.Method.ChangeProgArea(0);
        CheckApp.Method.Sleep(50);
        RenesasFgFp6.Method.EraseAndProgram(30000);
      </Method>
      <Text>程序下载程序-64K</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        RenesasFgFp6.Method.ChangeProgArea(1);
        CheckApp.Method.Sleep(50);
        RenesasFgFp6.Method.EraseAndProgram(30000);
      </Method>
      <Text>程序下载程序-三合一</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        RenesasFgFp6.Method.ChangeProgArea(4);
        CheckApp.Method.Sleep(50);
        RenesasFgFp6.Field.UniqueCodeStartAddr=0000C000;
        RenesasFgFp6.Field.UniqueCodeHexPattern=3322000180002E001A1049742101CF55;
        RenesasFgFp6.Method.SetUniqueCode();
        RenesasFgFp6.Method.EraseAndProgram(30000);
      </Method>
      <Text>测试写ECUID</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        RenesasFgFp6.Method.ChangeProgArea(2);
        CheckApp.Method.Sleep(50);
        RenesasFgFp6.Field.UniqueCodeStartAddr=FF20F780;
        RenesasFgFp6.Field.UniqueCodeHexPattern=44CCD547113BFEABCDEF7DDFF3548B66;
        RenesasFgFp6.Method.SetUniqueCode();
        RenesasFgFp6.Method.EraseAndProgram(30000);
      </Method>
      <Text>测试写ID_Code</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        RenesasFgFp6.Method.ChangeProgArea(3);
        CheckApp.Method.Sleep(50);
        RenesasFgFp6.Field.UniqueCodeStartAddr=FF20F7C0;
        RenesasFgFp6.Field.UniqueCodeHexPattern=46343736353638363331413139303734414141303030303031383231303730303030303030305801925F3A414101936D874343;
        RenesasFgFp6.Method.SetUniqueCode();
        RenesasFgFp6.Method.EraseAndProgram(30000);
      </Method>
      <Text>测试写版本信息</Text>
      <Para></Para>
    </Button>
    <!--<Button>
      <Method>
        RenesasFgFp6.Method.SetIdCode();
      </Method>
      <Text>写入ID-code</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        RenesasFgFp6.Method.ChangeAuthId();
      </Method>
      <Text>ChangeAuthenticationIdCode</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        RenesasFgFp6.Method.GetIdCode();
      </Method>
      <Text>读取ID-code</Text>
      <Para></Para>
    </Button>-->
  </Buttons>
  <GridDatas>
    <GridData>
      <Name>ICU-S</Name>
      <Type>RenesasFgFp6.Field.IcuSStatus</Type>
    </GridData>
    <GridData>
      <Name>烧写结果</Name>
      <Type>RenesasFgFp6.Field.ProgResult</Type>
    </GridData>
    <GridData>
      <Name>Authentication ID</Name>
      <Type>RenesasFgFp6.Field.AuthId</Type>
    </GridData>
    <GridData>
      <Name>需要写入的ID-Code</Name>
      <Type>RenesasFgFp6.Field.IdCodeToSet</Type>
    </GridData>
    <GridData>
      <Name>读取的ID-Code</Name>
      <Type>RenesasFgFp6.Field.IdCodeFromGet</Type>
    </GridData>
    <GridData>
      <Name>读取与写入的ID-Code对比</Name>
      <Type>RenesasFgFp6.Field.IdCodeCompare</Type>
    </GridData>
  </GridDatas>
</EmulatorConfig>