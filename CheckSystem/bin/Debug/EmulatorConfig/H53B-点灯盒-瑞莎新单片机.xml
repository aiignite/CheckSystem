<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <ShowTitle>H53B-点灯盒-V1.0</ShowTitle>
    <Init>
        <EnterFunction>
          SyRenesasMcuControllerMaster.Method.InitRemoteIpAddress(192.168.1.28:8088);
          H53B_HCM_HeadLamp.Field.Can=SyRenesasMcuControllerMaster.Field.GatewayCan1;
          H53B_HCM_HeadLamp.Method.LinStartScheduler();
        </EnterFunction>
    </Init>
    <ControllerConfig>
        <Controller>
            <ControllerType>H53B_HCM_HeadLamp</ControllerType>
            <ControllerName>H53B_HCM_HeadLamp</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>SyRenesasMcuControllerMaster</ControllerType>
            <ControllerName>SyRenesasMcuControllerMaster</ControllerName>
        </Controller>
    </ControllerConfig>
    <Buttons>
      <Button>
          <Method>
            H53B_HCM_HeadLamp.Method.TurnROn();
          </Method>
          <Text>右转向灯亮</Text>
          <Para></Para>
      </Button>
      <Button>
          <Method>
            H53B_HCM_HeadLamp.Method.TurnROff();
          </Method>         
        <Text>右转向灯灭</Text>
          <Para></Para>
      </Button>
      <Button>
          <Method>
            H53B_HCM_HeadLamp.Method.DrlROn();
          </Method>
          <Text>右日行灯亮</Text>
          <Para></Para>
      </Button>
      <Button>
          <Method>
            H53B_HCM_HeadLamp.Method.DrlROff();
          </Method>
          <Text>右日行灯灭</Text>
          <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.DrlLOn();
        </Method>
        <Text>左日行灯亮</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.DrlLOff();
        </Method>
        <Text>左日行灯灭</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.TailLOn();
        </Method>
        <Text>左位置灯亮</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.TailLOff();
        </Method>
        <Text>左位置灯灭</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.TailROn();
        </Method>
        <Text>右位置灯亮</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.TailROff();
        </Method>
        <Text>右位置灯灭</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.BCM_LowBeamReqOn();
        </Method>
        <Text>LB灯亮</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.BCM_LowBeamReqOff();
        </Method>
        <Text>LB灯灭</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.BCM_HighBeamReqOn();
        </Method>
        <Text>HB灯亮</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.BCM_HighBeamReqOff();
        </Method>
        <Text>HB灯灭</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.BCM_LeftTurnLampReqOn();
        </Method>
        <Text>左转向灯亮</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.BCM_LeftTurnLampReqOff();
        </Method>
        <Text>左转向灯灭</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.BCM_turnLampSerialReqOff();
        </Method>
        <Text>转向灯流水信号关</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.BCM_turnLampSerialReqOn();          
        </Method>
        <Text>转向灯流水信号开</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.LeftTurnLampFlickerOn();          
        </Method>
        <Text>左转向灯闪烁开始</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.LeftTurnLampFlickerOff();          
        </Method>
        <Text>左转向灯闪烁停止</Text>
        <Para></Para>   
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.RightTurnLampFlickerOn();          
        </Method>
        <Text>右转向灯闪烁开始</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.RightTurnLampFlickerOff();          
        </Method>
        <Text>右转向灯闪烁停止</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.MotorOn();          
        </Method>
        <Text>马达开始动作</Text>
        <Para></Para>
      </Button>
      <Button>
        <Method>
          H53B_HCM_HeadLamp.Method.MotorOff();          
        </Method>
        <Text>马达停止动作</Text>
        <Para></Para>
      </Button>
    </Buttons>
    <GridDatas>
    </GridDatas>
</EmulatorConfig>