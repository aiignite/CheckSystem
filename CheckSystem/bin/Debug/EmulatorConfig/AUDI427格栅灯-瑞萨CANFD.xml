<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <ShowTitle>AUDI427格栅灯-瑞萨Can</ShowTitle>
    <Init>
        <EnterFunction>
            SyRenesasMcuControllerMaster.Method.InitRemoteIpAddress(192.168.1.28:8088);
            Audi427CSuvGrilleLamp.Field.CanFd=SyRenesasMcuControllerMaster.Field.GatewayCan1;
            Audi427CSuvGrilleLamp.Method.StartCan();
        </EnterFunction>
    </Init>
    <ControllerConfig>
        <Controller>
            <ControllerType>SyRenesasMcuControllerMaster</ControllerType>
            <ControllerName>SyRenesasMcuControllerMaster</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>Audi427CSuvGrilleLamp</ControllerType>
            <ControllerName>Audi427CSuvGrilleLamp</ControllerName>
        </Controller>
    </ControllerConfig>
    <Buttons>
        <Button>
            <Method>
                Audi427CSuvGrilleLamp.Method.FroSigLampOn();
            </Method>
            <Text>点亮led</Text>
            <Para></Para>
        </Button>

        <Button>
            <Method>
                Audi427CSuvGrilleLamp.Method.AllPixelClose();
                Audi427CSuvGrilleLamp.Method.FroSigLampOff();
            </Method>
            <Text>关闭led</Text>
            <Para></Para>
        </Button>

        <Button>
            <Method>
                Audi427CSuvGrilleLamp.Method.FroSigLampPixel();
                Audi427CSuvGrilleLamp.Method.OddPixelClose();
                Audi427CSuvGrilleLamp.Method.OddPixelOpen(100.8);
            </Method>
            <Text>打开奇数像素</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                Audi427CSuvGrilleLamp.Method.FroSigLampPixel();
                Audi427CSuvGrilleLamp.Method.OddPixelClose();
                Audi427CSuvGrilleLamp.Method.EvenPixelOpen(100.8);
            </Method>
            <Text>打开偶数像素</Text>
            <Para></Para>
        </Button>

        <Button>
            <Method>
                Audi427CSuvGrilleLamp.Method.OpenRunMode(100.8);
            </Method>
            <Text>打开跑马灯</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                Audi427CSuvGrilleLamp.Method.CloseRunMode();
            </Method>
            <Text>关闭跑马灯</Text>
            <Para></Para>
        </Button>
    </Buttons>
</EmulatorConfig>