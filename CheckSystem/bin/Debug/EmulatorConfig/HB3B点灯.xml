<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <ShowTitle>HB3B点灯</ShowTitle>
    <Init>
        <EnterFunction>
            SyRenesasMcuControllerMaster.Method.InitRemoteIpAddress(192.168.1.28:8088);
            H53BHeadLamp.Field.LinWithBaudRate10417=SyRenesasMcuControllerMaster.Field.GatewayLin1;
            H53BHeadLamp.Method.LinStartScheduler();
        </EnterFunction>
    </Init>
    <ControllerConfig>
        <Controller>
            <ControllerType>H53BHeadLamp</ControllerType>
            <ControllerName>H53BHeadLamp</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>SyRenesasMcuControllerMaster</ControllerType>
            <ControllerName>SyRenesasMcuControllerMaster</ControllerName>
        </Controller>
    </ControllerConfig>
    <Buttons>

        <Button>
            <Method>
                H53BHeadLamp.Method.DrlOn();
            </Method>
            <Text>日行灯亮</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                H53BHeadLamp.Method.PlOn();
            </Method>
            <Text>位置灯亮</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                H53BHeadLamp.Method.TurnRunningOn();
            </Method>
            <Text>转向流水亮</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                H53BHeadLamp.Method.TurnHoldingOn();
            </Method>
            <Text>转向常亮</Text>
            <Para></Para>
        </Button>

        <Button>
            <Method>
                H53BHeadLamp.Method.LedOff();
            </Method>
            <Text>灯熄灭</Text>
            <Para></Para>
        </Button>
    </Buttons>
    <GridDatas>
    </GridDatas>
</EmulatorConfig>