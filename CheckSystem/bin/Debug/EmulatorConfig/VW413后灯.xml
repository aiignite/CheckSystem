<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <ShowTitle>VW413后灯</ShowTitle>
  <Init>
    <EnterFunction>
      SyControllerWith56Pin.Method.InitRemoteIpAddress(192.168.1.28:8088);
      Vw316RearLamp.Field.Lin19200=SyControllerWith56Pin.Field.GatewayLin;
      Vw316RearLamp.Method.LampAwake();
    </EnterFunction>
  </Init>
  <ControllerConfig>
    <Controller>
      <ControllerType>SyControllerWith56Pin</ControllerType>
      <ControllerName>SyControllerWith56Pin</ControllerName>
    </Controller>
    <Controller>
      <ControllerType>Vw316RearLamp</ControllerType>
      <ControllerName>Vw316RearLamp</ControllerName>
    </Controller>
  </ControllerConfig>
  <Buttons>
    <Button>
      <Method>
        Vw316RearLamp.Method.LampAwake();
      </Method>
      <Text>唤醒</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Vw316RearLamp.Method.LampSleep();
      </Method>
      <Text>休眠</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Vw316RearLamp.Method.StopOn();
      </Method>
      <Text>制动灯亮</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Vw316RearLamp.Method.StopOff();
      </Method>
      <Text>制动灯灭</Text>
      <Para></Para>
    </Button>

    <Button>
      <Method>
        Vw316RearLamp.Method.RearLampOn();
      </Method>
      <Text>位置灯低亮</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Vw316RearLamp.Method.RearLampHdOn();
      </Method>
      <Text>位置灯高亮开</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Vw316RearLamp.Method.RearLampOff();
      </Method>
      <Text>位置灯灭</Text>
      <Para></Para>
    </Button>

    <Button>
      <Method>
        Vw316RearLamp.Method.LeftRearTurnRunningOn();
        Vw316RearLamp.Method.RightRearTurnRunningOn();
      </Method>
      <Text>转向灯顺序亮</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Vw316RearLamp.Method.LeftRearTurnFlickerOn();
        Vw316RearLamp.Method.RightRearTurnFlickerOn();
      </Method>
      <Text>转向灯闪烁亮</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Vw316RearLamp.Method.LeftRearTurnOff();
        Vw316RearLamp.Method.RightRearTurnOff();
      </Method>
      <Text>转向灯灭</Text>
      <Para></Para>
    </Button>

    <Button>
      <Method>
        Vw316RearLamp.Method.LevingHome();
      </Method>
      <Text>离家动画</Text>
      <Para></Para>
    </Button>
    <Button>
      <Method>
        Vw316RearLamp.Method.ComingHome();
      </Method>
      <Text>回家动画</Text>
      <Para></Para>
    </Button>

    <Button>
      <Method>
        Vw316RearLamp.Method.AllLedOff();
      </Method>
      <Text>关闭所有灯光并打断动画</Text>
      <Para></Para>
    </Button>
  </Buttons>
</EmulatorConfig>