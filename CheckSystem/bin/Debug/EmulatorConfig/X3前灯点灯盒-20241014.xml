<?xml version="1.0" encoding="utf-8"?>
<EmulatorConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <ShowTitle>小鹏X3前灯-点灯盒</ShowTitle>
    <Init>
        <EnterFunction>
            SyRenesasMcuControllerMaster.Method.InitRemoteIpAddress(192.168.1.28:8088);
            XiaoPengX3FrontLamp.Field.Can=SyRenesasMcuControllerMaster.Field.GatewayCan1;
            XiaoPengX3FrontLamp.Field.IsLConnect=1;
            XiaoPengX3FrontLamp.Field.IsRConnect=1;
            XiaoPengX3FrontLamp.Method.StartCanMsg();
        </EnterFunction>
    </Init>
    <ControllerConfig>
        <Controller>
            <ControllerType>XiaoPengX3FrontLamp</ControllerType>
            <ControllerName>XiaoPengX3FrontLamp</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>ToomossUsb2XxxCanLin</ControllerType>
            <ControllerName>ToomossUsb2XxxCanLin</ControllerName>
        </Controller>
        <Controller>
            <ControllerType>SyRenesasMcuControllerMaster</ControllerType>
            <ControllerName>SyRenesasMcuControllerMaster</ControllerName>
        </Controller>
    </ControllerConfig>
    <Buttons>

        <Button>
            <Method>
                XiaoPengX3FrontLamp.Method.LbOn();
            </Method>
            <Text>近光灯亮</Text>
            <Para></Para>
        </Button>
        <Button>
            <Method>
                XiaoPengX3FrontLamp.Method.LbOff();
            </Method>
            <Text>近光灯灭</Text>
            <Para></Para>
        </Button>
