connect '/C=#COM#'
sendln 'ver'
wait '>'
sendln 'clear'
wait '>'
sendln 'downprm'
wait 'Now loading...'
sendfile '#prmFile#' 1
wait '>'
sendln 'downset fname="#setName#"'
wait 'Now loading...'
sendfile '#setFile#' 1
wait '>'
sendln 'lod fname="#lodName#" ftime="#time#"'
wait 'Now loading...'
sendfile '#lodFile#' 1
wait '>'
closett
end