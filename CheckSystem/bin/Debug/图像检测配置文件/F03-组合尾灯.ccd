FO3RearLamp.Method.RightRearPosCtrl(02);
FO3RearLamp.Method.MidLeftRearPosCtrl(02);
FO3RearLamp.Method.MidRightRearPosCtrl(02);
FO3RearLamp.Method.MiddleLeftBulOnOff(02);
FO3RearLamp.Method.MiddleRightBulOnOff(02);
FO3RearLamp.Method.RearLogoCtrl(02);
FO3RearLamp.Method.RearADSOnOff(2);
CheckApp.Method.Sleep(1000);
FO3RearLamp.Method.ReadDtc();
FO3RearLamp.Method.ClearDtc();
</ParaMethodsBefore>
                <ParaMethodsAfter>FO3RearLamp.Method.LeftTiBrightSet(101);
FO3RearLamp.Method.RightTiBrightSet(101);
FO3RearLamp.Method.LeftTiOnOff(01);
FO3RearLamp.Method.RightTiOnOff(01);
FO3RearLamp.Method.LeftStopOnOff(01);
FO3RearLamp.Method.RightStopOnOff(01);
