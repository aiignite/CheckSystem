FO3RearLamp.Method.LeftTiBrightSet(60);
FO3RearLamp.Method.RightTiBrightSet(60);
FO3RearLamp.Method.LeftTiOnOff(02);
FO3RearLamp.Method.RightTiOnOff(02);
CheckApp.Method.Sleep(1000);
FO3RearLamp.Method.LeftTiOnOff(01);
FO3RearLamp.Method.RightTiOnOff(01);
FO3RearLamp.Method.LeftStopOnOff(02);
FO3RearLamp.Method.RightStopOnOff(02);
